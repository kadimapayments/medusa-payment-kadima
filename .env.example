# Per-merchant Kadima credentials (Phase-0 #1 — each merchant supplies their own).
# If Kadima confirms one token spans both gateway + ACH hosts, set both to the same value.
KADIMA_CARD_TOKEN=your_per_merchant_gateway_token
KADIMA_ACH_TOKEN=your_per_merchant_ach_token

# Merchant identifiers
KADIMA_TERMINAL_ID=24        # card gateway (terminal.id → MID/TID)
KADIMA_DBA_ID=5              # ACH (dba.id)

# Webhook signing secret(s) — one per endpoint, from the Kadima dashboard
KADIMA_WEBHOOK_SECRET=your_webhook_signing_secret

# Card capture model: "auth" (authorize then capture) or "sale" (auth+capture)
KADIMA_CARD_CAPTURE_METHOD=auth
