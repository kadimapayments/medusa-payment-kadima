{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": ".medusa/server",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["node_modules", ".medusa", "**/*.test.ts"]
}
